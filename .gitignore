# OS / editor
.DS_Store
*.swp
*.swo
.vscode/
.idea/

# Node
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Environment — every variant of dotenv files, in case a tooling
# convention slips one past the .env / .env.local / .env.*.local trio.
.env
.env.*
.envrc
!.env.example

# Secret material — pinned by test/gitignore-secret-patterns.test.js.
# Adding a new pattern here must also update the test's required list.
*.pem
*.key
*.p12
*.pfx
*.cer
*.crt
id_rsa
id_rsa.pub
id_ed25519
id_ed25519.pub
.ssh/
secrets/
credentials.json
service-account*.json
gha-cache-key.txt

# Vercel
.vercel

# Build / cache
.cache/
dist/
out/

# Logs
logs/
*.log

# Claude / agent transient state
/tmp/
*.pdf
!docs/*.pdf
