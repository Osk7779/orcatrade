# OrcaTrade — environment-variable contract
#
# Copy to .env.local for local dev (never commit .env.local).
# In production, set every required var on Vercel → Settings → Environment Variables.
#
# Convention:
#   REQUIRED  — handler returns 503 / falls back if missing
#   OPTIONAL  — sensible default; override only when you need to
#   DEV-ONLY  — set in .env.local; never set on Vercel

# ─────────────────────────────────────────────────────
# Site basics
# ─────────────────────────────────────────────────────
# OPTIONAL  Origin used in absolute URLs (magic-link emails, Stripe success/cancel
#           URLs, RSS feed self-link). Defaults to https://orcatrade.pl.
SITE_ORIGIN=https://orcatrade.pl

# ─────────────────────────────────────────────────────
# Vercel KV (Upstash Redis REST) — Sprint 37
# ─────────────────────────────────────────────────────
# REQUIRED in production. If unset, lib/intelligence/kv-store.js falls back to
# an in-process Map — fine for local dev, NOT durable across cold starts.
# Auth tokens, saved plans, tier records, and event log all live here.
KV_REST_API_URL=
KV_REST_API_TOKEN=
# OPTIONAL aliases — set either pair, kv-store.js reads both.
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# ─────────────────────────────────────────────────────
# Magic-link auth — Sprint 38
# ─────────────────────────────────────────────────────
# REQUIRED  HMAC secret for session cookies. Generate with:
#           openssl rand -hex 32
# In dev, lib/auth.js falls back to a hash of VERCEL_GIT_COMMIT_SHA so cookies
# don't survive a deploy — never rely on that fallback in production.
ORCATRADE_AUTH_SECRET=

# ─────────────────────────────────────────────────────
# Resend transactional email — Sprint 38, lead routing
# ─────────────────────────────────────────────────────
# REQUIRED  Resend API key for magic-link delivery + plan-summary emails.
RESEND_API_KEY=
# REQUIRED  Verified sender. If missing, defaults to the generic
#           onboarding@resend.dev — that WILL trigger spam filters in
#           production. Verify orcatrade.pl in Resend, then set this.
RESEND_FROM=OrcaTrade <hello@orcatrade.pl>
# OPTIONAL  Inbox where founder-side lead notifications go.
ORCATRADE_LEADS_INBOX=leads@orcatrade.pl

# ─────────────────────────────────────────────────────
# Anthropic — agent handlers (Sprints 12–26)
# ─────────────────────────────────────────────────────
# REQUIRED for agent endpoints (compliance, sourcing, logistics, finance,
# orchestrator). Without it those handlers return 503.
ANTHROPIC_API_KEY=
# OPTIONAL  Alias read by some legacy handlers; either var works.
ORCATRADE_OS_API=

# ─────────────────────────────────────────────────────
# Stripe billing — Sprint 41
# ─────────────────────────────────────────────────────
# REQUIRED in production. /api/billing/checkout returns 503 without it.
# Use sk_test_… until you're ready to take live money.
STRIPE_SECRET_KEY=
# REQUIRED  Endpoint-secret from the Stripe Dashboard webhook settings.
#           Used for HMAC-SHA256 signature verification on /api/billing/webhook.
STRIPE_WEBHOOK_SECRET=
# REQUIRED (one per tier × cycle). Resolved dynamically by
# lib/stripe.js:priceIdFor(tierId, cycle) → STRIPE_PRICE_<TIER>_<CYCLE>.
# Create these prices in Stripe Dashboard with metadata.tier_id +
# metadata.billing_cycle matching the env-var name.
STRIPE_PRICE_STARTER_MONTHLY=
STRIPE_PRICE_STARTER_ANNUAL=
STRIPE_PRICE_GROWTH_MONTHLY=
STRIPE_PRICE_GROWTH_ANNUAL=
STRIPE_PRICE_SCALE_MONTHLY=
STRIPE_PRICE_SCALE_ANNUAL=

# ─────────────────────────────────────────────────────
# Conversion analytics — Sprint 36
# ─────────────────────────────────────────────────────
# REQUIRED to access /dashboard/leads/. /api/leads returns 503 if unset,
# 401 if the token in the URL doesn't match. Generate with:
#   openssl rand -hex 24
ORCATRADE_LEADS_TOKEN=

# ─────────────────────────────────────────────────────
# Compliance reports — runtime-store report links
# ─────────────────────────────────────────────────────
# OPTIONAL  HMAC secret for signed report-download URLs. Falls back to a
#           hash of VERCEL_GIT_COMMIT_SHA in dev.
ORCATRADE_REPORT_SECRET=
# OPTIONAL  Override for signed-URL TTL (ms). Default: 604_800_000 (7 days).
ORCATRADE_REPORT_TOKEN_TTL_MS=

# OPTIONAL  Namespace prefix on KV keys — useful when running staging +
#           production against the same KV instance. Default: ''.
ORCATRADE_STORE_PREFIX=

# ─────────────────────────────────────────────────────
# Vercel-injected (do NOT set manually)
# ─────────────────────────────────────────────────────
# Vercel sets these automatically on every deploy. Listed here only so
# searching for "process.env." finds a complete catalogue.
# VERCEL=1
# VERCEL_GIT_COMMIT_SHA=<sha>
# NODE_ENV=production
