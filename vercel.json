{
  "cleanUrls": true,
  "functions": {
    "api/[...path].js": { "maxDuration": 60 }
  },
  "redirects": [
    { "source": "/app", "destination": "/app/dashboard", "permanent": false },
    { "source": "/app/", "destination": "/app/dashboard", "permanent": false }
  ],
  "rewrites": [
    {
      "source": "/app/:path*",
      "destination": "https://orcatrade-c2i5.vercel.app/app/:path*"
    },
    { "source": "/feed.xml", "destination": "/api/feed?format=rss" },
    { "source": "/atom.xml", "destination": "/api/feed?format=atom" },
    { "source": "/share/:code", "destination": "/api/share/:code" },
    { "source": "/api/:path+", "destination": "/api/[...path]" },

    {
      "source": "/_next/:path*",
      "destination": "https://orcatrade-marketing.vercel.app/_next/:path*"
    },

    { "source": "/changelog", "destination": "https://orcatrade-marketing.vercel.app/changelog" },
    { "source": "/pricing", "destination": "https://orcatrade-marketing.vercel.app/pricing" },
    { "source": "/status", "destination": "https://orcatrade-marketing.vercel.app/status" },
    { "source": "/trust/anchors", "destination": "https://orcatrade-marketing.vercel.app/trust/anchors" },
    { "source": "/partners", "destination": "https://orcatrade-marketing.vercel.app/partners" },
    { "source": "/press", "destination": "https://orcatrade-marketing.vercel.app/press" },
    { "source": "/platform", "destination": "https://orcatrade-marketing.vercel.app/platform" },
    { "source": "/marketplace", "destination": "https://orcatrade-marketing.vercel.app/marketplace" },
    { "source": "/customs", "destination": "https://orcatrade-marketing.vercel.app/customs" },
    { "source": "/routing", "destination": "https://orcatrade-marketing.vercel.app/routing" },
    { "source": "/warehouse", "destination": "https://orcatrade-marketing.vercel.app/warehouse" },
    { "source": "/insurance", "destination": "https://orcatrade-marketing.vercel.app/insurance" },
    { "source": "/samples", "destination": "https://orcatrade-marketing.vercel.app/samples" },
    { "source": "/returns", "destination": "https://orcatrade-marketing.vercel.app/returns" },
    { "source": "/documents", "destination": "https://orcatrade-marketing.vercel.app/documents" },
    { "source": "/supply-chain", "destination": "https://orcatrade-marketing.vercel.app/supply-chain" },
    { "source": "/compliance", "destination": "https://orcatrade-marketing.vercel.app/compliance" },
    { "source": "/portfolio", "destination": "https://orcatrade-marketing.vercel.app/portfolio" },
    { "source": "/agent", "destination": "https://orcatrade-marketing.vercel.app/agent" },
    { "source": "/signup", "destination": "https://orcatrade-marketing.vercel.app/signup" },
    { "source": "/signin", "destination": "https://orcatrade-marketing.vercel.app/signin" },
    { "source": "/agents", "destination": "https://orcatrade-marketing.vercel.app/agents" },
    { "source": "/analysis", "destination": "https://orcatrade-marketing.vercel.app/analysis" },
    { "source": "/buyer-verification", "destination": "https://orcatrade-marketing.vercel.app/buyer-verification" },
    { "source": "/contact", "destination": "https://orcatrade-marketing.vercel.app/contact" },
    { "source": "/factory-risk", "destination": "https://orcatrade-marketing.vercel.app/factory-risk" },
    { "source": "/finance", "destination": "https://orcatrade-marketing.vercel.app/finance" },
    { "source": "/founding", "destination": "https://orcatrade-marketing.vercel.app/founding" },
    { "source": "/intelligence", "destination": "https://orcatrade-marketing.vercel.app/intelligence" },
    { "source": "/logistics", "destination": "https://orcatrade-marketing.vercel.app/logistics" },
    { "source": "/process", "destination": "https://orcatrade-marketing.vercel.app/process" },
    { "source": "/regulations", "destination": "https://orcatrade-marketing.vercel.app/regulations" },
    { "source": "/search", "destination": "https://orcatrade-marketing.vercel.app/search" },
    { "source": "/sourcing", "destination": "https://orcatrade-marketing.vercel.app/sourcing" },
    { "source": "/trust", "destination": "https://orcatrade-marketing.vercel.app/trust" },
    { "source": "/examples", "destination": "https://orcatrade-marketing.vercel.app/examples" },

    {
      "source": "/",
      "destination": "https://orcatrade-marketing.vercel.app/"
    },
    {
      "source": "/pl",
      "destination": "https://orcatrade-marketing.vercel.app/pl"
    },
    {
      "source": "/de",
      "destination": "https://orcatrade-marketing.vercel.app/de"
    },

    { "source": "/pl/changelog", "destination": "https://orcatrade-marketing.vercel.app/changelog" },
    { "source": "/pl/status", "destination": "https://orcatrade-marketing.vercel.app/status" },
    { "source": "/pl/trust", "destination": "https://orcatrade-marketing.vercel.app/trust" },
    { "source": "/pl/trust/anchors", "destination": "https://orcatrade-marketing.vercel.app/trust/anchors" },
    { "source": "/pl/portfolio", "destination": "https://orcatrade-marketing.vercel.app/portfolio" },
    { "source": "/pl/signin", "destination": "https://orcatrade-marketing.vercel.app/signin" },
    { "source": "/pl/signup", "destination": "https://orcatrade-marketing.vercel.app/signup" },
    { "source": "/pl/contact", "destination": "https://orcatrade-marketing.vercel.app/contact" },
    { "source": "/pl/process", "destination": "https://orcatrade-marketing.vercel.app/process" },

    { "source": "/de/changelog", "destination": "https://orcatrade-marketing.vercel.app/changelog" },
    { "source": "/de/status", "destination": "https://orcatrade-marketing.vercel.app/status" },
    { "source": "/de/trust", "destination": "https://orcatrade-marketing.vercel.app/trust" },
    { "source": "/de/trust/anchors", "destination": "https://orcatrade-marketing.vercel.app/trust/anchors" },
    { "source": "/de/portfolio", "destination": "https://orcatrade-marketing.vercel.app/portfolio" },
    { "source": "/de/signin", "destination": "https://orcatrade-marketing.vercel.app/signin" },
    { "source": "/de/signup", "destination": "https://orcatrade-marketing.vercel.app/signup" },
    { "source": "/de/contact", "destination": "https://orcatrade-marketing.vercel.app/contact" },
    { "source": "/de/process", "destination": "https://orcatrade-marketing.vercel.app/process" }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "Strict-Transport-Security",
          "value": "max-age=63072000; includeSubDomains; preload"
        },
        {
          "key": "X-Content-Type-Options",
          "value": "nosniff"
        },
        {
          "key": "X-Frame-Options",
          "value": "SAMEORIGIN"
        },
        {
          "key": "Referrer-Policy",
          "value": "strict-origin-when-cross-origin"
        },
        {
          "key": "Permissions-Policy",
          "value": "camera=(), microphone=(), geolocation=(), payment=(), usb=(), interest-cohort=()"
        },
        {
          "key": "Cross-Origin-Opener-Policy",
          "value": "same-origin"
        },
        {
          "key": "X-DNS-Prefetch-Control",
          "value": "on"
        },
        {
          "key": "Content-Security-Policy",
          "value": "default-src 'self'; base-uri 'self'; object-src 'none'; frame-ancestors 'self'; form-action 'self'; script-src 'self' 'unsafe-inline' 'unsafe-eval' https://cdn.jsdelivr.net https://va.vercel-scripts.com; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com https://cdn.jsdelivr.net; font-src 'self' data: https://fonts.gstatic.com https://cdn.jsdelivr.net; img-src 'self' data: https: blob:; connect-src 'self' https://va.vercel-scripts.com https://*.vercel.app; manifest-src 'self'; worker-src 'self' blob:; upgrade-insecure-requests"
        }
      ]
    }
  ]
}
